# ─────────────────────────────────────────────────────────────
# Digital Access — Variables d'environnement
# Copiez ce fichier vers .env et renseignez les valeurs.
# ─────────────────────────────────────────────────────────────

# Database (Neon PostgreSQL serverless)
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/digital-access?sslmode=require"

# Auth.js v5
AUTH_SECRET="générez avec: npx auth secret"
AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Resend (emails transactionnels)
RESEND_API_KEY=""
EMAIL_FROM="Access Academy <noreply@digitalaccess.ci>"
EMAIL_REPLY_TO="contact@digitalaccess.ci"

# Paiement Mobile Money (CinetPay)
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""
CINETPAY_SECRET_KEY=""

# Stockage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=""

# IA — Import de prospect par fichier (Word/PDF) via Claude (Anthropic)
# Créez une clé sur https://console.anthropic.com/ puis collez-la ci-dessous.
ANTHROPIC_API_KEY=""
# Modèle utilisé pour l'extraction (optionnel, défaut: claude-sonnet-5)
ANTHROPIC_MODEL="claude-sonnet-5"
# Taille max des documents importés en Mo (optionnel, défaut: 15)
CRM_MAX_DOC_MB="15"

# Temps réel (Ably)
ABLY_API_KEY=""

# Monitoring (Sentry)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# URLs publiques
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_ACADEMY_URL="http://localhost:3001"

# Contact
NEXT_PUBLIC_WHATSAPP_NUMBER="2250700000000"
NEXT_PUBLIC_CONTACT_EMAIL="contact@digitalaccess.ci"
