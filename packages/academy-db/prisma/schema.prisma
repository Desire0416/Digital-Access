// ═══════════════════════════════════════════════════════════════════════════
// ACCESS ACADEMY — Base de données DÉDIÉE (Neon, séparée de la base du web).
// Schéma conforme au cahier des charges fonctionnel (sections 41, 42, 43).
//
// PRINCIPE CENTRAL (règles métier 40.1 → 40.8) :
//   La FORMATION (Course) est la brique pédagogique unique, créée UNE SEULE
//   fois. Elle est réutilisée — jamais dupliquée — via des JONCTIONS :
//     · SchoolCourse      → une formation appartient à plusieurs écoles
//     · CareerPathCourse  → un parcours ASSEMBLE des formations existantes
//     · SchoolCareerPath  → une école regroupe des parcours existants
//   Une formation validée reste acquise (reconnaissance dans tout parcours)
//   et n'est jamais facturée deux fois (déduction du prix du parcours).
// ═══════════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("ACADEMY_DATABASE_URL")
  directUrl = env("ACADEMY_DATABASE_URL_UNPOOLED")
}

// ─── Utilisateurs & rôles (section 7) ────────────────────────────────────────

enum Role {
  LEARNER // apprenant
  INSTRUCTOR // formateur
  GRADER // correcteur
  MENTOR // mentor / tuteur
  SCHOOL_MANAGER // responsable d'école
  PATH_MANAGER // responsable de parcours
  ORG_MANAGER // responsable entreprise
  ACADEMIC_ADMIN // administrateur pédagogique
  SALES_ADMIN // administrateur commercial
  SUPER_ADMIN
}

model User {
  id              String    @id @default(cuid())
  firstName       String?
  lastName        String?
  name            String // nom d'affichage
  email           String    @unique
  password        String? // null pour OAuth seul
  avatar          String?
  bio             String?
  country         String?
  phone           String?
  objective       String? // onboarding 15.4
  experienceLevel String? // onboarding 15.4
  roles           Role[]    @default([LEARNER])
  emailVerified   DateTime?
  isActive        Boolean   @default(false)
  lastActiveAt    DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tokens                VerificationToken[]
  enrollments           Enrollment[]
  pathEnrollments       CareerPathEnrollment[]
  lessonProgress        LessonProgress[]
  attempts              AssessmentAttempt[]
  submissions           Submission[]
  reviewedSubmissions   Submission[]           @relation("SubmissionReviewer")
  certificates          Certificate[]
  payments              Payment[]
  processedPayments     Payment[]              @relation("PaymentProcessor")
  reviews               Review[]
  favorites             Favorite[]
  notifications         Notification[]
  courseInstructorships CourseInstructor[]
  orgMemberships        OrganizationMember[]
  auditLogs             AuditLog[]
  portfolio             Portfolio?
  equivalenceRequests   EquivalenceRequest[]   @relation("EquivalenceLearner")
  reviewedEquivalences  EquivalenceRequest[]   @relation("EquivalenceReviewer")
  cohortMemberships     CohortMember[]
  cohortInstructorships CohortInstructor[]
  eventRegistrations    EventRegistration[]
  hostedEvents          Event[]                @relation("EventHost")
  announcements         Announcement[]         @relation("AnnouncementAuthor")
  discussions           Discussion[]           @relation("DiscussionAuthor")
  discussionReplies     DiscussionReply[]      @relation("ReplyAuthor")
  discussionFollows     DiscussionFollow[]
  lessonComments        LessonComment[]        @relation("CommentAuthor")
  reactions             Reaction[]
  reportsFiled          Report[]               @relation("Reporter")
  reportsReviewed       Report[]               @relation("ReportReviewer")
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  type      TokenType
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ─── Statuts de contenu (section 41.1) ───────────────────────────────────────

enum ContentStatus {
  DRAFT
  REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  SUSPENDED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

// ─── École (section 14) — regroupe, ne duplique jamais ───────────────────────

model School {
  id          String        @id @default(cuid())
  code        String?       @unique // ex. "S01"
  name        String
  slug        String        @unique
  tagline     String?
  description String
  coverImage  String?
  icon        String        @default("graduation-cap")
  color       String        @default("#5b3fa8")
  order       Int           @default(0)
  status      ContentStatus @default(PUBLISHED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  courses     SchoolCourse[]
  careerPaths SchoolCareerPath[]
  programs    Program[]
  cohorts     Cohort[]
  events      Event[]
  discussions Discussion[]
}

// ─── Formation (sections 10-12) — LA brique centrale, unique ────────────────

enum UnlockMode {
  FREE // libre
  SEQUENTIAL // séquentiel
}

model Course {
  id                String        @id @default(cuid())
  code              String?       @unique // ex. "AI-001", "CORE-005"
  title             String
  slug              String        @unique
  subtitle          String?
  description       String // markdown
  objectives        String[]      @default([])
  targetAudience    String[]      @default([])
  prerequisitesText String[]      @default([]) // affichage libre (11.2)
  tools             String[]      @default([])
  level             CourseLevel   @default(BEGINNER)
  language          String        @default("fr")
  durationHours     Int?
  price             Int           @default(0) // FCFA
  coverImage        String?
  promoVideoUrl     String?
  certificateTitle  String?
  badgeTitle        String? // badge remis à la validation
  priority          String? // "Vague 1", "Vague 2", "Vague 3"
  unlockMode        UnlockMode    @default(FREE)
  featured          Boolean       @default(false)
  status            ContentStatus @default(DRAFT)
  publishedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  modules             Module[]
  assessments         Assessment[]
  projects            Project[]
  resources           Resource[]
  skills              CourseSkill[]
  instructors         CourseInstructor[]
  schools             SchoolCourse[]
  careerPaths         CareerPathCourse[]
  programs            ProgramCourse[]
  enrollments         Enrollment[]
  reviews             Review[]
  certificates        Certificate[]
  favorites           Favorite[]
  payments            Payment[]
  // prérequis structurés (22.1) : cette formation exige d'autres formations
  requires            CoursePrerequisite[] @relation("CourseRequires")
  requiredBy          CoursePrerequisite[] @relation("CourseRequiredBy")
  equivalenceRequests EquivalenceRequest[]
  cohorts             Cohort[]
  events              Event[]
  announcements       Announcement[]
  discussions         Discussion[]
  lessonComments      LessonComment[]      @relation("CourseLessonComments")
}

/// Prérequis structuré : `course` exige la validation de `requiresCourse`.
model CoursePrerequisite {
  id               String @id @default(cuid())
  courseId         String
  course           Course @relation("CourseRequires", fields: [courseId], references: [id], onDelete: Cascade)
  requiresCourseId String
  requiresCourse   Course @relation("CourseRequiredBy", fields: [requiresCourseId], references: [id], onDelete: Cascade)

  @@unique([courseId, requiresCourseId])
}

model CourseInstructor {
  id        String @id @default(cuid())
  courseId  String
  course    Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleLabel String @default("Formateur") // Formateur principal, Tuteur…
  order     Int    @default(0)

  @@unique([courseId, userId])
}

model Module {
  id              String        @id @default(cuid())
  courseId        String
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  objectives      String[]      @default([])
  order           Int           @default(0)
  durationMinutes Int?
  status          ContentStatus @default(PUBLISHED)

  lessons     Lesson[]
  assessments Assessment[]

  @@index([courseId])
}

// Types de leçons (12.2)
enum LessonType {
  VIDEO
  TEXT
  PDF
  AUDIO
  PRESENTATION
  INTERACTIVE
  DEMO
  EXTERNAL_LINK
  VIRTUAL_CLASS
  CASE_STUDY
  WORKSHOP
  LAB
}

model Lesson {
  id              String        @id @default(cuid())
  moduleId        String
  module          Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title           String
  lessonType      LessonType    @default(TEXT)
  content         String? // markdown
  videoUrl        String?
  externalUrl     String?
  durationMinutes Int?
  order           Int           @default(0)
  isPreview       Boolean       @default(false)
  isRequired      Boolean       @default(true) // progression = activités obligatoires (règle 40.10)
  status          ContentStatus @default(PUBLISHED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  resources Resource[]
  progress  LessonProgress[]
  comments  LessonComment[]

  @@index([moduleId])
}

// Types de ressources (12.3)
enum ResourceType {
  PDF
  DOC
  SHEET
  SLIDES
  ZIP
  CODE
  IMAGE
  AUDIO
  VIDEO
  LINK
  TEMPLATE
  DATASET
}

model Resource {
  id       String       @id @default(cuid())
  lessonId String?
  lesson   Lesson?      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  courseId String?
  course   Course?      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  kind     ResourceType @default(LINK)
  url      String
  order    Int          @default(0)

  @@index([lessonId])
  @@index([courseId])
}

// ─── Évaluations (section 18) ────────────────────────────────────────────────

enum AssessmentType {
  QUIZ // correction automatique
  ASSIGNMENT // devoir / dépôt — correction manuelle
  EXAM // examen
}

model Assessment {
  id               String         @id @default(cuid())
  courseId         String
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleId         String?
  module           Module?        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  type             AssessmentType @default(QUIZ)
  passingScore     Int            @default(60)
  attemptsAllowed  Int            @default(0) // 0 = illimité
  durationMinutes  Int?
  shuffleQuestions Boolean        @default(false)
  weight           Int            @default(1) // pondération dans la note finale
  isRequired       Boolean        @default(true)
  order            Int            @default(0)
  status           ContentStatus  @default(PUBLISHED)

  questions Question[]
  attempts  AssessmentAttempt[]

  @@index([courseId])
  @@index([moduleId])
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  LONG_ANSWER
  MATCHING
  ORDERING
}

model Question {
  id            String       @id @default(cuid())
  assessmentId  String
  assessment    Assessment   @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  type          QuestionType @default(SINGLE_CHOICE)
  question      String
  options       Json?
  correctAnswer Json? // SINGLE_CHOICE=index · MULTIPLE_CHOICE=index[] · TRUE_FALSE=bool(true=Vrai)
  explanation   String?
  points        Int          @default(1)
  order         Int          @default(0)

  @@index([assessmentId])
}

// Statuts d'évaluation (41.3)
enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  PASSED
  FAILED
  RETAKE_REQUIRED
}

model AssessmentAttempt {
  id            String        @id @default(cuid())
  assessmentId  String
  assessment    Assessment    @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  attemptNumber Int           @default(1)
  answers       Json?
  score         Int?
  passed        Boolean?
  status        AttemptStatus @default(SUBMITTED)
  feedback      String?
  startedAt     DateTime      @default(now())
  submittedAt   DateTime?
  gradedAt      DateTime?
  gradedById    String?

  @@index([assessmentId])
  @@index([userId])
}

// ─── Projets (section 19) ────────────────────────────────────────────────────

model Project {
  id           String        @id @default(cuid())
  courseId     String?
  course       Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  careerPathId String? // projet transversal de parcours (13.8)
  careerPath   CareerPath?   @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  title        String
  context      String // markdown
  objectives   String[]      @default([])
  deliverables String[]      @default([])
  rubric       String? // grille d'évaluation (markdown)
  minScore     Int           @default(60)
  maxAttempts  Int           @default(2)
  isRequired   Boolean       @default(true)
  order        Int           @default(0)
  status       ContentStatus @default(PUBLISHED)

  submissions Submission[]

  @@index([courseId])
  @@index([careerPathId])
}

// Statuts de projet (41.4)
enum SubmissionStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  CHANGES_REQUESTED
  APPROVED
  REJECTED
}

model Submission {
  id            String           @id @default(cuid())
  projectId     String
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  attemptNumber Int              @default(1)
  content       String? // texte de présentation
  links         Json? // liens (GitHub, vidéo, portfolio…)
  files         Json? // fichiers déposés (URLs Blob)
  status        SubmissionStatus @default(DRAFT)
  score         Int?
  feedback      String?
  reviewerId    String?
  reviewer      User?            @relation("SubmissionReviewer", fields: [reviewerId], references: [id])
  submittedAt   DateTime?
  reviewedAt    DateTime?
  isPublic      Boolean          @default(false) // publiée au portfolio (§19.5)
  publishedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  portfolioItem PortfolioItem?

  @@index([projectId])
  @@index([userId])
  @@index([status])
}

// ─── Portfolio & employabilité (sections 16.7 / 19.5) ────────────────────────
// « Pas d'employabilité sans preuve » : un projet VALIDÉ peut être publié au
// portfolio (PortfolioItem lié à la Submission → jamais dupliqué). Le portfolio
// public agrège présentation, compétences, projets, certificats, expériences.

model Portfolio {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug      String   @unique // URL publique /portfolio/[slug]
  isPublic  Boolean  @default(false)
  headline  String? // intitulé professionnel (ex. « Analyste de données junior »)
  about     String? // présentation (markdown)
  tools     String[] @default([]) // outils & technologies maîtrisés
  links     Json? // { github, linkedin, website, … }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PortfolioItem[]

  @@index([isPublic])
}

enum PortfolioItemType {
  PROJECT // issu d'une soumission validée
  EXPERIENCE // expérience saisie manuellement
  LINK // réalisation externe
}

model PortfolioItem {
  id           String            @id @default(cuid())
  portfolioId  String
  portfolio    Portfolio         @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  type         PortfolioItemType @default(PROJECT)
  title        String
  description  String?
  url          String?
  image        String?
  skills       String[]          @default([])
  order        Int               @default(0)
  // Origine : soumission validée (unique → publication idempotente + trace la preuve).
  submissionId String?           @unique
  submission   Submission?       @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  createdAt    DateTime          @default(now())

  @@index([portfolioId])
}

// ─── Compétences (section 21) ────────────────────────────────────────────────

enum SkillLevel {
  DISCOVERY
  BEGINNER
  OPERATIONAL
  ADVANCED
  EXPERT
}

model Skill {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  domain      String?
  description String?

  courses CourseSkill[]
}

model CourseSkill {
  courseId    String
  course      Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  skillId     String
  skill       Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)
  targetLevel SkillLevel @default(OPERATIONAL)
  isPrimary   Boolean    @default(false)

  @@id([courseId, skillId])
  @@index([skillId])
}

// ─── Parcours métier (section 13) — ASSEMBLE des formations existantes ──────

model CareerPath {
  id                 String        @id @default(cuid())
  code               String?       @unique // ex. "PATH-AI-01"
  title              String
  slug               String        @unique
  targetJob          String
  description        String // markdown
  missions           String[]      @default([])
  outcomes           String[]      @default([])
  entryLevel         CourseLevel   @default(BEGINNER)
  exitLevel          CourseLevel   @default(ADVANCED)
  duration           String? // libellé, ex. « 9 mois »
  rhythm             String? // ex. « 10 h / semaine »
  price              Int           @default(0) // FCFA — prix plein, avant déduction des acquis
  installments       String? // ex. « 4 mensualités de 50 000 F CFA »
  certificationTitle String?
  coverImage         String?
  featured           Boolean       @default(false)
  priority           String? // "Vague 1", "Vague 2", "Vague 3"
  status             ContentStatus @default(DRAFT)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  phases       CareerPathPhase[]
  courses      CareerPathCourse[]
  programs     CareerPathProgram[]
  schools      SchoolCareerPath[]
  enrollments  CareerPathEnrollment[]
  projects     Project[] // projet(s) transversal(aux)
  certificates Certificate[]
  favorites    Favorite[]
  payments     Payment[]
  cohorts      Cohort[]
  events       Event[]
  discussions  Discussion[]
}

model CareerPathPhase {
  id           String     @id @default(cuid())
  careerPathId String
  careerPath   CareerPath @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  title        String // ex. Fondations, Spécialisation… (13.5)
  description  String?
  order        Int        @default(0)

  courses CareerPathCourse[]

  @@index([careerPathId])
}

/// JONCTION CRITIQUE (43.2) : composition d'un parcours à partir de formations
/// existantes — position, phase, obligatoire/optionnelle, prérequis interne.
model CareerPathCourse {
  id                   String           @id @default(cuid())
  careerPathId         String
  careerPath           CareerPath       @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  courseId             String
  course               Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  phaseId              String?
  phase                CareerPathPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  position             Int              @default(0)
  isRequired           Boolean          @default(true)
  prerequisiteCourseId String? // formation à valider avant celle-ci, dans CE parcours
  creditValue          Int?

  @@unique([careerPathId, courseId])
  @@index([courseId])
}

/// JONCTION (43.1) : rattachement école ↔ formation, avec rattachement principal.
model SchoolCourse {
  id         String  @id @default(cuid())
  schoolId   String
  school     School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  isPrimary  Boolean @default(false)
  isFeatured Boolean @default(false)
  position   Int     @default(0)

  @@unique([schoolId, courseId])
  @@index([courseId])
}

/// JONCTION (43.3) : rattachement école ↔ parcours.
model SchoolCareerPath {
  id           String     @id @default(cuid())
  schoolId     String
  school       School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  careerPathId String
  careerPath   CareerPath @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  isPrimary    Boolean    @default(false)
  position     Int        @default(0)

  @@unique([schoolId, careerPathId])
  @@index([careerPathId])
}

// ─── Inscriptions & progression (sections 16, 41.2) ─────────────────────────

enum EnrollmentStatus {
  PENDING // en attente (ex. paiement à valider)
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
  EXPIRED
}

enum EnrollmentOrigin {
  DIRECT
  CAREER_PATH
  ORGANIZATION
  COHORT
}

enum AccessType {
  PAID
  FREE
  COUPON
  EQUIVALENCE
  ORGANIZATION
  MANUAL
}

/// RÈGLE 40.6 : une formation apparaît UNE SEULE fois par apprenant, même si
/// elle appartient à plusieurs parcours → @@unique(userId, courseId).
model Enrollment {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course           @relation(fields: [courseId], references: [id])
  status      EnrollmentStatus @default(ACTIVE)
  origin      EnrollmentOrigin @default(DIRECT)
  accessType  AccessType       @default(PAID)
  progress    Int              @default(0) // % — calculé sur les activités obligatoires
  enrolledAt  DateTime         @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  expiresAt   DateTime?

  lessonProgress LessonProgress[]

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([status])
}

model CareerPathEnrollment {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerPathId String
  careerPath   CareerPath       @relation(fields: [careerPathId], references: [id])
  status       EnrollmentStatus @default(ACTIVE)
  progress     Int              @default(0)
  enrolledAt   DateTime         @default(now())
  completedAt  DateTime?

  @@unique([userId, careerPathId])
  @@index([careerPathId])
}

model LessonProgress {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  enrollmentId String
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  completedAt  DateTime   @default(now())

  @@unique([userId, lessonId])
  @@index([enrollmentId])
}

// ─── Équivalences / VAE (section 22.3-22.4) ─────────────────────────────────
// L'apprenant dépose une preuve (certificat, diplôme, portfolio, expérience,
// résultat de test) pour faire reconnaître une formation. Un administrateur
// valide : acceptée (dispense totale → Enrollment COMPLETED via EQUIVALENCE),
// partielle (accès gratuit à compléter → Enrollment ACTIVE), conditionnelle ou
// refusée (aucun accès, motif). INVARIANT : le dépôt ne donne JAMAIS accès —
// seule la validation admin crée une inscription.

enum EquivalenceEvidenceType {
  CERTIFICATE // certificat
  DIPLOMA // diplôme
  PORTFOLIO // portfolio
  EXPERIENCE // preuve d'expérience
  TEST // résultat de test
}

enum EquivalenceStatus {
  PENDING // en attente de validation
  ACCEPTED // acceptée — dispense totale
  PARTIAL // partielle — accès accordé, à compléter
  CONDITIONAL // conditionnelle — accès sous condition (motif)
  REJECTED // refusée
}

model EquivalenceRequest {
  id           String                  @id @default(cuid())
  userId       String
  user         User                    @relation("EquivalenceLearner", fields: [userId], references: [id], onDelete: Cascade)
  courseId     String
  course       Course                  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  evidenceType EquivalenceEvidenceType
  description  String // justification de l'apprenant
  proofUrl     String? // capture / document (Blob)
  proofLink    String? // lien externe (certificat en ligne, portfolio…)
  status       EquivalenceStatus       @default(PENDING)
  reviewNote   String? // motif / condition (admin)
  reviewedById String?
  reviewedBy   User?                   @relation("EquivalenceReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  // ⚠️ Index partiel d'unicité HORS Prisma (cf. partial-indexes.sql) :
  // au plus UNE demande PENDING par (userId, courseId) →
  //   "EquivalenceRequest_pending_uq".

  @@index([userId])
  @@index([courseId])
  @@index([status])
}

// ─── Certificats (section 20, 41.6) ─────────────────────────────────────────

enum CertificateType {
  PARTICIPATION
  COURSE
  SPECIALIZATION
  EXPERTISE
  CAREER_PATH
  SKILL_BADGE
}

enum CertificateStatus {
  ACTIVE
  SUSPENDED
  REVOKED
  EXPIRED
  REPLACED
}

model Certificate {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId      String?
  course        Course?           @relation(fields: [courseId], references: [id])
  careerPathId  String?
  careerPath    CareerPath?       @relation(fields: [careerPathId], references: [id])
  type          CertificateType   @default(COURSE)
  title         String
  number        String            @unique // ex. DA-2026-XXXXXX
  verifyCode    String            @unique // code public de vérification
  status        CertificateStatus @default(ACTIVE)
  score         Int?
  mention       String? // Bien, Très bien…
  skills        String[]          @default([]) // instantané des compétences
  issuedAt      DateTime          @default(now())
  expiresAt     DateTime?
  revokedAt     DateTime?
  revokedReason String?
  // ⚠️ Index partiels d'unicité maintenus HORS Prisma (raw SQL, cf.
  // packages/academy-db/prisma/partial-indexes.sql) — un seul certificat ACTIF
  // par (userId, courseId, type) et par (userId, careerPathId, type) :
  //   "Certificate_active_course_uq", "Certificate_active_path_uq".

  @@index([userId])
}

// ─── Paiements (section 27, 41.5) ────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  FAILED
  CANCELLED
  REFUNDED
  EXPIRED
}

enum PaymentProvider {
  MOBILE_MONEY
  CARD
  TRANSFER
  MANUAL
  COUPON
  ORGANIZATION
}

enum PaymentPurpose {
  COURSE
  CAREER_PATH
  COHORT
  CERTIFICATION
  OTHER
}

model Payment {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  amount        Int // FCFA
  currency      String          @default("XOF")
  provider      PaymentProvider @default(MOBILE_MONEY)
  status        PaymentStatus   @default(PENDING)
  purpose       PaymentPurpose  @default(COURSE)
  courseId      String?
  course        Course?         @relation(fields: [courseId], references: [id])
  careerPathId  String?
  careerPath    CareerPath?     @relation(fields: [careerPathId], references: [id])
  cohortId      String?
  cohort        Cohort?         @relation(fields: [cohortId], references: [id])
  reference     String?         @unique // ID de transaction Mobile Money (anti-doublon)
  operator      String? // ORANGE / MTN / WAVE
  payerPhone    String?
  proofUrl      String? // capture de la preuve
  rejectReason  String?
  metadata      Json?
  couponCode    String?
  processedById String?
  processedBy   User?           @relation("PaymentProcessor", fields: [processedById], references: [id])
  processedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  // ⚠️ Index partiels d'unicité maintenus HORS Prisma (raw SQL, cf.
  // packages/academy-db/prisma/partial-indexes.sql) — au plus UN paiement
  // PENDING par (userId, courseId) et par (userId, careerPathId) :
  //   "Payment_pending_course_uq", "Payment_pending_path_uq".

  @@index([userId])
  @@index([status])
}

enum DiscountType {
  PERCENT
  FIXED
}

model Coupon {
  id           String       @id @default(cuid())
  code         String       @unique
  discountType DiscountType @default(PERCENT)
  value        Int
  maxUses      Int?
  usedCount    Int          @default(0)
  expiresAt    DateTime?
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
}

// ─── Avis, favoris, notifications (sections 11.10, 16.8, 26) ────────────────

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

model Review {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  rating    Int // 1..5
  comment   String?
  status    ModerationStatus @default(APPROVED)
  createdAt DateTime         @default(now())

  @@unique([userId, courseId]) // un seul avis par utilisateur (11.10)
  @@index([courseId])
}

model Favorite {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId     String?
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  careerPathId String?
  careerPath   CareerPath? @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())

  @@index([userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String    @default("SYSTEM")
  title     String
  message   String
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
}

// ─── Cohortes & événements (sections 23, 24) ─────────────────────────────────
// Une COHORTE (§23) est un groupe daté qui suit ENSEMBLE une formation OU un
// parcours (jamais dupliqué — on cible la brique existante). Les ÉVÉNEMENTS
// (§24 : webinaire, classe virtuelle, atelier, soutenance…) sont UNIFIÉS dans un
// seul modèle `Event` : un événement rattaché à une cohorte (`cohortId`) est une
// SESSION de cette cohorte ; sans `cohortId`, c'est un événement autonome
// (public ou réservé aux inscrits). Inscription / lien / présence / rappel /
// replay / ressources / compte rendu s'appliquent aux deux.
//
// INVARIANT (miroir du paiement) : rejoindre une cohorte GRATUITE crée le
// `CohortMember` + l'inscription pédagogique sous-jacente ; une cohorte PAYANTE
// passe par le tunnel de paiement (Payment PENDING, purpose COHORT) et SEULE
// l'approbation admin crée l'accès (cf. lib/payments.ts).

enum CohortType {
  AUTONOMOUS // autonome
  GUIDED // accompagnée
  INTENSIVE // intensive
  ENTERPRISE // entreprise
  HYBRID // hybride
  VIRTUAL_CLASS // classe virtuelle
}

enum CohortStatus {
  DRAFT // brouillon
  OPEN // inscriptions ouvertes
  RUNNING // en cours
  COMPLETED // terminée
  CANCELLED // annulée
}

enum CohortMemberStatus {
  PENDING // inscription en attente (paiement à valider)
  ACTIVE // membre actif
  COMPLETED // a terminé la cohorte
  WITHDRAWN // retiré / abandon
}

model Cohort {
  id                 String       @id @default(cuid())
  code               String?      @unique
  name               String
  slug               String       @unique
  type               CohortType   @default(GUIDED)
  description        String? // markdown (présentation, §23)
  rules              String? // markdown (règles de la cohorte, §23.2)
  // Cible pédagogique : formation OU parcours (contrôle applicatif : exactement un).
  courseId           String?
  course             Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  careerPathId       String?
  careerPath         CareerPath?  @relation(fields: [careerPathId], references: [id], onDelete: SetNull)
  schoolId           String?
  school             School?      @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  startDate          DateTime
  endDate            DateTime?
  enrollmentDeadline DateTime? // date limite d'inscription (§23.2)
  capacity           Int? // effectif max (§23.2) ; null = illimité
  price              Int? // FCFA ; null = prix de la cible sous-jacente
  rhythm             String? // ex. « 10 h / semaine »
  coverImage         String?
  status             CohortStatus @default(DRAFT)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  members       CohortMember[]
  instructors   CohortInstructor[]
  events        Event[]
  announcements Announcement[]
  payments      Payment[]
  discussions   Discussion[]

  @@index([courseId])
  @@index([careerPathId])
  @@index([schoolId])
  @@index([status])
}

model CohortMember {
  id          String             @id @default(cuid())
  cohortId    String
  cohort      Cohort             @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      CohortMemberStatus @default(ACTIVE)
  joinedAt    DateTime           @default(now())
  completedAt DateTime?

  @@unique([cohortId, userId]) // un apprenant n'apparaît qu'une fois par cohorte
  @@index([userId])
  @@index([status])
}

model CohortInstructor {
  id        String @id @default(cuid())
  cohortId  String
  cohort    Cohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleLabel String @default("Formateur")

  @@unique([cohortId, userId])
  @@index([userId])
}

// Types d'événement (§24.1)
enum EventType {
  WEBINAR // webinaire
  VIRTUAL_CLASS // classe virtuelle
  WORKSHOP // atelier
  DEFENSE // soutenance
  MENTORING // mentorat
  CONFERENCE // conférence
  QA_SESSION // session de questions
}

// Intégrations visio (§24.2)
enum EventProvider {
  GOOGLE_MEET
  ZOOM
  TEAMS
  JITSI
  IN_PERSON // présentiel
  OTHER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

// Qui peut s'inscrire / voir un événement.
enum EventAudience {
  PUBLIC // ouvert à tous (inscription libre)
  ENROLLED // réservé aux inscrits de la formation/parcours lié
  COHORT // réservé aux membres de la cohorte
}

model Event {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  description  String? // markdown
  type         EventType     @default(WEBINAR)
  audience     EventAudience @default(PUBLIC)
  startAt      DateTime
  endAt        DateTime?
  timezone     String        @default("Africa/Abidjan")
  provider     EventProvider @default(GOOGLE_MEET)
  meetingUrl   String? // lien de connexion (§24.3)
  location     String? // présentiel / hybride
  capacity     Int?
  coverImage   String?
  speakerName  String? // intervenant (texte libre)
  hostId       String?
  host         User?         @relation("EventHost", fields: [hostId], references: [id], onDelete: SetNull)
  // Rattachement : session de cohorte (cohortId) et/ou contexte pédagogique.
  cohortId     String?
  cohort       Cohort?       @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  courseId     String?
  course       Course?       @relation(fields: [courseId], references: [id], onDelete: SetNull)
  careerPathId String?
  careerPath   CareerPath?   @relation(fields: [careerPathId], references: [id], onDelete: SetNull)
  schoolId     String?
  school       School?       @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  replayUrl    String? // replay (§24.3)
  summary      String? // compte rendu (§24.3, markdown)
  resources    Json? // ressources : [{ title, url, kind }] (§24.3)
  status       EventStatus   @default(DRAFT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  registrations EventRegistration[]

  @@index([cohortId])
  @@index([courseId])
  @@index([careerPathId])
  @@index([schoolId])
  @@index([startAt])
  @@index([status])
}

model EventRegistration {
  id           String    @id @default(cuid())
  eventId      String
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  registeredAt DateTime  @default(now())
  attended     Boolean   @default(false) // présence (§24.3)
  attendedAt   DateTime?
  remindedAt   DateTime? // rappel envoyé (§24.3) — anti-doublon du cron

  @@unique([eventId, userId])
  @@index([userId])
}

// Annonces (§23.3, §25.1) — d'une cohorte ou d'une formation ; alimentent le
// tableau de bord apprenant (§16.1 « annonces »).
model Announcement {
  id        String   @id @default(cuid())
  cohortId  String?
  cohort    Cohort?  @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  courseId  String?
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?    @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  title     String
  body      String // markdown
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cohortId])
  @@index([courseId])
  @@index([createdAt])
}

// ─── Communauté & modération (sections 25, 5.1) ──────────────────────────────
// Forum contextualisé (§25.1) : une DISCUSSION appartient à UN espace — une
// formation, un parcours, une école OU une cohorte (contrôle applicatif :
// exactement un contexte). Réponses en fil (parentId), solution marquée,
// épinglage/verrou par la modération (§25.3). Les COMMENTAIRES PAR LEÇON
// (§5.1/§7.3) = modèle distinct, rendus dans le lecteur. Réactions et
// signalements sont POLYMORPHES (targetType + targetId) pour couvrir les trois
// cibles sans multiplier les tables.

model Discussion {
  id           String      @id @default(cuid())
  title        String
  body         String // markdown
  courseId     String?
  course       Course?     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  careerPathId String?
  careerPath   CareerPath? @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  schoolId     String?
  school       School?     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  cohortId     String?
  cohort       Cohort?     @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  authorId     String?
  author       User?       @relation("DiscussionAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  pinned       Boolean     @default(false)
  locked       Boolean     @default(false) // verrouillée : plus de réponses (§25.3)
  solved       Boolean     @default(false)
  attachments  Json? // pièces jointes (images Blob) : [{ url, name }]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  replies DiscussionReply[]
  follows DiscussionFollow[]

  @@index([courseId])
  @@index([careerPathId])
  @@index([schoolId])
  @@index([cohortId])
  @@index([createdAt])
}

model DiscussionReply {
  id           String            @id @default(cuid())
  discussionId String
  discussion   Discussion        @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  authorId     String?
  author       User?             @relation("ReplyAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  parentId     String? // réponse à une réponse (fil §25.2)
  parent       DiscussionReply?  @relation("ReplyThread", fields: [parentId], references: [id], onDelete: SetNull)
  children     DiscussionReply[] @relation("ReplyThread")
  body         String
  isSolution   Boolean           @default(false)
  attachments  Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([discussionId])
  @@index([parentId])
}

model DiscussionFollow {
  id           String     @id @default(cuid())
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([discussionId, userId])
  @@index([userId])
}

model LessonComment {
  id        String          @id @default(cuid())
  lessonId  String
  lesson    Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  courseId  String // dénormalisé pour le cloisonnement d'accès (inscription)
  course    Course          @relation("CourseLessonComments", fields: [courseId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?           @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  parentId  String?
  parent    LessonComment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: SetNull)
  children  LessonComment[] @relation("CommentThread")
  body      String
  pinned    Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([lessonId])
  @@index([courseId])
  @@index([parentId])
}

enum ReactionTarget {
  DISCUSSION
  REPLY
  LESSON_COMMENT
}

model Reaction {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType ReactionTarget
  targetId   String
  createdAt  DateTime       @default(now())

  @@unique([userId, targetType, targetId]) // une réaction par cible et par utilisateur
  @@index([targetType, targetId])
}

enum ReportTarget {
  DISCUSSION
  REPLY
  LESSON_COMMENT
}

enum ReportStatus {
  PENDING
  ACTIONED
  DISMISSED
}

model Report {
  id           String       @id @default(cuid())
  reporterId   String?
  reporter     User?        @relation("Reporter", fields: [reporterId], references: [id], onDelete: SetNull)
  targetType   ReportTarget
  targetId     String
  reason       String
  status       ReportStatus @default(PENDING)
  note         String? // note du modérateur (§25.3)
  reviewedById String?
  reviewedBy   User?        @relation("ReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  createdAt    DateTime     @default(now())

  @@index([status])
  @@index([targetType, targetId])
}

// ─── Entreprises (section 28) — socle minimal, développé en Phase 3 ─────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String?
  phone     String?
  createdAt DateTime @default(now())

  members OrganizationMember[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  isManager      Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
}

// ─── Journal d'audit (sections 30.1, 46) ─────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String // ex. certificate.revoke, grade.update, payment.approve
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId])
}

// ─── Programme de compétences (catalogue maître) ─────────────────────────────
// Assemblage cohérent de formations conduisant à une micro-certification.
// Réutilisable dans plusieurs parcours métiers via CareerPathProgram.

model Program {
  id                 String        @id @default(cuid())
  code               String        @unique // ex. "PRG-AI-01"
  title              String
  slug               String        @unique
  description        String?       @db.Text
  volume             Int? // durée totale en heures
  price              Int           @default(0) // FCFA
  certificationTitle String? // micro-certification
  coverImage         String?
  priority           String? // "Vague 1", "Vague 2"
  status             ContentStatus @default(DRAFT)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  schoolId    String?
  school      School?             @relation(fields: [schoolId], references: [id])
  courses     ProgramCourse[]
  careerPaths CareerPathProgram[]

  @@index([schoolId])
}

/// JONCTION : composition d'un programme à partir de formations existantes.
model ProgramCourse {
  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  courseId   String
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  position  Int     @default(0)

  @@id([programId, courseId])
  @@index([courseId])
}

/// JONCTION : composition d'un parcours métier à partir de programmes.
model CareerPathProgram {
  careerPathId String
  careerPath   CareerPath @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  programId    String
  program      Program    @relation(fields: [programId], references: [id], onDelete: Cascade)
  position     Int        @default(0)
  isRequired   Boolean    @default(true)

  @@id([careerPathId, programId])
  @@index([programId])
}
