// ─────────────────────────────────────────────────────────────────────────────
// Digital Access — Schéma Prisma unifié
// Couvre les deux applications : apps/web (Solutions) et apps/academy (Academy).
// Un compte unique, plusieurs rôles cumulables. Montants en FCFA (Int, sans décimale).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  // `rhel-openssl-3.0.x` = runtime serverless Vercel (en plus de la machine locale).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ═══════════════════════════════ ENUMS ══════════════════════════════════════

enum UserRole {
  LEARNER
  CLIENT
  INSTRUCTOR
  MENTOR
  REVIEWER
  COMPANY
  ACADEMIC_MANAGER
  ADMIN
  SUPER_ADMIN
  // Pôle Solutions — CRM commercial (ajoutés en fin de liste : append Postgres sûr)
  COMMERCIAL
  CHEF_PROJET
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ── Pôle Solutions ──
enum LeadStatus {
  NEW
  CONTACTED
  QUOTE_SENT
  NEGOTIATION
  WON
  LOST
}

enum ProjectType {
  SITE_VITRINE
  SITE_INSTITUTIONNEL
  ELEARNING
  REFONTE
  MAINTENANCE
  OTHER
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  DELIVERED
  MAINTENANCE
  ARCHIVED
}

enum StageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum MaintenancePlan {
  BASIC
  STANDARD
  PREMIUM
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

