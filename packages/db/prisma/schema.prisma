// ═══════════════════════════════ USER & AUTH ════════════════════════════════

model User {
  id                String     @id @default(cuid())
  name              String
  email             String     @unique
  password          String? // null pour comptes OAuth uniquement
  avatar            String?
  bio               String?
  location          String?
  phone             String?
  website           String?
  roles             UserRole[] @default([LEARNER])
  emailVerified     DateTime?
  isActive          Boolean    @default(false)
  streak            Int        @default(0)
  xp                Int        @default(0)
  lastActiveAt      DateTime?
  deletedAt         DateTime? // soft delete (rétention 30j)
  notificationPrefs Json? // { email: {COURSE_ENROLLED: bool, ...}, inApp: {...} } — null = tout activé
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Auth.js
  accounts           Account[]
  sessions           Session[]
  verificationTokens VerificationToken[]

  // Pôle Solutions
  assignedLeads       Lead[]                @relation("LeadAssignee")
  projects            Project[]             @relation("ClientProjects")
  invoices            Invoice[]
  maintenanceContract MaintenanceContract[]
  tickets             Ticket[]
  ticketMessages      TicketMessage[]
  projectMessages     ProjectMessage[]

  // Pôle Solutions — CRM commercial
  ownedOrganizations     Organization[]  @relation("OrgOwner")
  assignedProspects      Prospect[]      @relation("ProspectAssignee")
  createdProspects       Prospect[]      @relation("ProspectCreator")
  authoredAudits         Audit[]         @relation("AuditAuthor")
  validatedAudits        Audit[]         @relation("AuditValidator")
  sentAudits             Audit[]         @relation("AuditSender")
  uploadedAuditDocuments AuditDocument[] @relation("AuditDocUploader")
  createdActivities      Activity[]      @relation("ActivityCreator")
  assignedCrmTasks       Task[]          @relation("TaskAssignee")
  createdCrmTasks        Task[]          @relation("TaskCreator")
  assignedDeals          Deal[]          @relation("DealAssignee")
  createdQuotes          Quote[]         @relation("QuoteCreator")
  uploadedDocuments      CrmDocument[]   @relation("DocUploader")
  commercialProjects     Project[]       @relation("ProjectCommercialOwner")
  managedProjects        Project[]       @relation("ProjectManager")

  // Pôle Academy (refonte)
  learnerProfile      LearnerProfile?
  enrollments         Enrollment[]
  lessonProgress      LessonProgress[]
  learnerBadges       LearnerBadge[]
  certificates        Certificate[]
  portfolioItems      PortfolioItem[]
  submissions         ProjectSubmission[] @relation("LearnerSubmissions")
  reviewedSubmissions ProjectSubmission[] @relation("ReviewerSubmissions")
  quizAttempts        QuizAttempt[]
  applications        Application[]
  companyProfile      Company?            @relation("CompanyOwner")

  // Transversal
  payments      Payment[]
  notifications Notification[]
  blogPosts     BlogPost[]

  @@index([email])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  type      TokenType
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

// ═══════════════════════════════ PÔLE SOLUTIONS ═════════════════════════════

model Lead {
  id          String      @id @default(cuid())
  name        String
  email       String
  phone       String?
  company     String?
  projectType ProjectType
  budget      String?
  timeline    String?
  message     String
  documents   String[]    @default([])
  status      LeadStatus  @default(NEW)
  source      String? // devis, contact, référence...
  notes       String?
  assigneeId  String?
  assignee    User?       @relation("LeadAssignee", fields: [assigneeId], references: [id])
  project     Project?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // ── Enrichissement CRM (additif, nullable) ──
  organizationId      String?
  organization        Organization? @relation(fields: [organizationId], references: [id])
  priority            Priority?
  qualificationStatus String? // nouveau, à-qualifier, qualifié, non-qualifié, converti, fermé, spam…
  nextAction          String?
  nextActionDate      DateTime?
  lastActivityAt      DateTime?
  archivedAt          DateTime?
  deal                Deal?      @relation("DealInboundLead")
  activities          Activity[]
  tasks               Task[]

  @@index([status])
  @@index([createdAt])
  @@index([organizationId])
}

model Project {
  id          String        @id @default(cuid())
  clientId    String
  client      User          @relation("ClientProjects", fields: [clientId], references: [id])
  leadId      String?       @unique
  lead        Lead?         @relation(fields: [leadId], references: [id])
  title       String
  slug        String        @unique
  type        ProjectType
  description String
  budget      Int? // FCFA
  status      ProjectStatus @default(PENDING)
  startDate   DateTime?
  endDate     DateTime?
  liveUrl     String?
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // ── Origine commerciale (CRM, additif nullable) ──
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id])
  dealId            String?       @unique
  deal              Deal?         @relation("DealProject", fields: [dealId], references: [id])
  auditId           String?
  audit             Audit?        @relation("ProjectAudit", fields: [auditId], references: [id])
  quoteId           String?       @unique
  quote             Quote?        @relation("QuoteProject", fields: [quoteId], references: [id])
  primaryContactId  String?
  primaryContact    Contact?      @relation("ProjectPrimaryContact", fields: [primaryContactId], references: [id])
  commercialOwnerId String?
  commercialOwner   User?         @relation("ProjectCommercialOwner", fields: [commercialOwnerId], references: [id])
  projectManagerId  String?
  projectManager    User?         @relation("ProjectManager", fields: [projectManagerId], references: [id])
  sourceType        String? // LEAD | PROSPECT | DEAL | MANUAL
  sourceId          String?
  commercialSummary String?
  initialNeed       String?
  validatedScope    String?

  stages     ProjectStage[]
  invoices   Invoice[]
  tickets    Ticket[]
  messages   ProjectMessage[]
  contract   MaintenanceContract?
  activities Activity[]
  tasks      Task[]

  @@index([clientId])
  @@index([status])
  @@index([organizationId])
  @@index([projectManagerId])
  @@index([commercialOwnerId])
}

model ProjectStage {
  id           String      @id @default(cuid())
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  status       StageStatus @default(PENDING)
  position     Int
  deliverables String[]    @default([]) // URLs Vercel Blob
  completedAt  DateTime?
  createdAt    DateTime    @default(now())

  @@index([projectId])
}

model Invoice {
  id        String        @id @default(cuid())
  projectId String?
  project   Project?      @relation(fields: [projectId], references: [id])
  clientId  String
  client    User          @relation(fields: [clientId], references: [id])
  number    String        @unique
  items     Json // [{ label, quantity, unitPrice }]
  amount    Int // sous-total FCFA
  tax       Int           @default(0)
  total     Int // FCFA
  status    InvoiceStatus @default(DRAFT)
  dueDate   DateTime?
  paidAt    DateTime?
  pdfUrl    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
}

model MaintenanceContract {
  id            String          @id @default(cuid())
  projectId     String          @unique
  project       Project         @relation(fields: [projectId], references: [id])
  clientId      String
  client        User            @relation(fields: [clientId], references: [id])
  plan          MaintenancePlan
  services      String[]        @default([])
  startDate     DateTime
  endDate       DateTime
  autoRenew     Boolean         @default(true)
  monthlyAmount Int // FCFA
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([clientId])
}

model Ticket {
  id          String          @id @default(cuid())
  projectId   String?
  project     Project?        @relation(fields: [projectId], references: [id])
  clientId    String
  client      User            @relation(fields: [clientId], references: [id])
  title       String
  description String
  priority    TicketPriority  @default(MEDIUM)
  status      TicketStatus    @default(OPEN)
  attachments String[]        @default([])
  messages    TicketMessage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([clientId])
  @@index([status])
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  content     String
  attachments String[] @default([])
  createdAt   DateTime @default(now())

  @@index([ticketId])
}

model ProjectMessage {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  content     String
  attachments String[] @default([])
  createdAt   DateTime @default(now())

  @@index([projectId])
}

// ═══════════════════════════════ PÔLE ACADEMY ═══════════════════════════════
// Académie orientée compétences : École → Parcours métier → Module → Leçon →
// Quiz → Projets professionnels → Dépôts → Badges → Portfolio → Certificats →
// Opportunités. Refonte complète (2026) — cf. docs/academy/.

model School {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  shortDescription String
  longDescription  String?
  icon             String?
  image            String?
  color            String?
  order            Int           @default(0)
  status           ContentStatus @default(PUBLISHED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  careerPaths  CareerPath[]
  shortCourses ShortCourse[]
  skills       Skill[]
  projects     ProfessionalProject[]

  @@index([slug])
}

model LearnerProfile {
  id           String              @id @default(cuid())
  userId       String              @unique
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline     String?
  bio          String?
  city         String?
  country      String?             @default("Côte d'Ivoire")
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?
  availability String?
  careerGoal   String?
  visibility   PortfolioVisibility @default(PRIVATE)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model CareerPath {
  id               String        @id @default(cuid())
  schoolId         String
  school           School        @relation(fields: [schoolId], references: [id])
  title            String
  slug             String        @unique
  shortDescription String
  longDescription  String?
  targetJob        String
  level            Level         @default(BEGINNER)
  duration         String? // libellé, ex. « 3 mois »
  estimatedHours   Int?
  price            Int           @default(0) // FCFA
  prerequisites    String[]      @default([])
  objectives       String[]      @default([])
  outcomes         String[]      @default([])
  tools            String[]      @default([])
  certificateTitle String?
  coverImage       String?
  featured         Boolean       @default(false)
  status           ContentStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  modules      Module[]
  skills       CareerPathSkill[]
  projects     ProfessionalProject[]
  enrollments  Enrollment[]
  certificates Certificate[]

  @@index([schoolId])
  @@index([slug])
  @@index([status])
}

model ShortCourse {
  id               String        @id @default(cuid())
  schoolId         String
  school           School        @relation(fields: [schoolId], references: [id])
  title            String
  slug             String        @unique
  shortDescription String
  longDescription  String?
  level            Level         @default(BEGINNER)
  duration         String?
  price            Int           @default(0) // FCFA
  courseType       String? // initiation, atelier, outil, module bonus…
  objectives       String[]      @default([])
  prerequisites    String[]      @default([])
  coverImage       String?
  featured         Boolean       @default(false)
  status           ContentStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  modules      Module[]
  enrollments  Enrollment[]
  certificates Certificate[]

  @@index([schoolId])
  @@index([slug])
  @@index([status])
}

model Module {
  id                String        @id @default(cuid())
  careerPathId      String?
  careerPath        CareerPath?   @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  shortCourseId     String?
  shortCourse       ShortCourse?  @relation(fields: [shortCourseId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  order             Int           @default(0)
  objectives        String[]      @default([])
  estimatedDuration Int? // minutes
  status            ContentStatus @default(PUBLISHED)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  lessons  Lesson[]
  quizzes  Quiz[]
  projects ProfessionalProject[]

  @@index([careerPathId])
  @@index([shortCourseId])
}

model Lesson {
  id                String        @id @default(cuid())
  moduleId          String
  module            Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title             String
  slug              String
  content           String? // markdown / MDX
  videoUrl          String?
  lessonType        LessonType    @default(VIDEO)
  resources         Json?
  order             Int           @default(0)
  estimatedDuration Int? // minutes
  isPreview         Boolean       @default(false)
  status            ContentStatus @default(PUBLISHED)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  quizzes     Quiz[]
  completions LessonProgress[]

  @@index([moduleId])
}

model Skill {
  id          String        @id @default(cuid())
  schoolId    String?
  school      School?       @relation(fields: [schoolId], references: [id])
  name        String
  slug        String        @unique
  description String?
  category    SkillCategory @default(TECHNICAL)
  level       Level         @default(BEGINNER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  careerPaths CareerPathSkill[]
  badges      Badge[]

  @@index([schoolId])
  @@index([category])
}

model CareerPathSkill {
  careerPathId String
  careerPath   CareerPath @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  skillId      String
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([careerPathId, skillId])
  @@index([skillId])
}

model Quiz {
  id              String        @id @default(cuid())
  lessonId        String?
  lesson          Lesson?       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  moduleId        String?
  module          Module?       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  passingScore    Int           @default(70)
  attemptsAllowed Int           @default(0) // 0 = illimité
  status          ContentStatus @default(PUBLISHED)
  createdAt       DateTime      @default(now())

  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([lessonId])
  @@index([moduleId])
}

model QuizQuestion {
  id            String           @id @default(cuid())
  quizId        String
  quiz          Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question      String
  type          QuizQuestionType @default(SINGLE_CHOICE)
  options       Json?
  correctAnswer Json
  explanation   String?
  points        Int              @default(1)
  order         Int              @default(0)

  @@index([quizId])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  learnerId   String
  learner     User      @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  score       Int       @default(0)
  passed      Boolean   @default(false)
  answers     Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([quizId])
  @@index([learnerId])
}

model ProfessionalProject {
  id                  String                  @id @default(cuid())
  schoolId            String?
  school              School?                 @relation(fields: [schoolId], references: [id])
  careerPathId        String?
  careerPath          CareerPath?             @relation(fields: [careerPathId], references: [id])
  moduleId            String?
  module              Module?                 @relation(fields: [moduleId], references: [id])
  title               String
  slug                String                  @unique
  projectType         ProfessionalProjectType @default(MINI_PROJECT)
  level               Level                   @default(BEGINNER)
  context             String?
  problem             String?
  mission             String?
  objectives          String[]                @default([])
  deliverables        String[]                @default([])
  resources           Json?
  constraints         String[]                @default([])
  estimatedDuration   Int? // heures
  requiresSubmission  Boolean                 @default(true)
  requiresDefense     Boolean                 @default(false)
  isPortfolioEligible Boolean                 @default(true)
  rubricId            String?
  rubric              Rubric?                 @relation(fields: [rubricId], references: [id])
  status              ContentStatus           @default(DRAFT)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  submissions    ProjectSubmission[]
  badges         Badge[]
  portfolioItems PortfolioItem[]

  @@index([schoolId])
  @@index([careerPathId])
  @@index([slug])
}

model Rubric {
  id           String   @id @default(cuid())
  title        String
  description  String?
  totalPoints  Int      @default(100)
  passingScore Int      @default(70)
  criteria     Json // [{ label, points, description }]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects ProfessionalProject[]
}

model ProjectSubmission {
  id            String              @id @default(cuid())
  projectId     String
  project       ProfessionalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  learnerId     String
  learner       User                @relation("LearnerSubmissions", fields: [learnerId], references: [id], onDelete: Cascade)
  files         Json?
  links         Json?
  comment       String?
  aiDeclaration String?
  status        SubmissionStatus    @default(IN_PROGRESS)
  score         Int?
  feedback      String?
  reviewerId    String?
  reviewer      User?               @relation("ReviewerSubmissions", fields: [reviewerId], references: [id])
  version       Int                 @default(1)
  submittedAt   DateTime?
  reviewedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([projectId])
  @@index([learnerId])
  @@index([status])
}

model Badge {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  description String
  category    BadgeCategory        @default(TECHNICAL_SKILL)
  level       Level?
  icon        String?
  criteria    String?
  skillId     String?
  skill       Skill?               @relation(fields: [skillId], references: [id])
  projectId   String?
  project     ProfessionalProject? @relation(fields: [projectId], references: [id])
  status      ContentStatus        @default(PUBLISHED)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  learnerBadges LearnerBadge[]

  @@index([slug])
  @@index([category])
}

model LearnerBadge {
  id           String           @id @default(cuid())
  learnerId    String
  learner      User             @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  badgeId      String
  badge        Badge            @relation(fields: [badgeId], references: [id])
  evidenceType String?
  evidenceId   String?
  issuedAt     DateTime         @default(now())
  status       CredentialStatus @default(ACTIVE)

  @@unique([learnerId, badgeId])
  @@index([learnerId])
}

model Certificate {
  id                String              @id @default(cuid())
  learnerId         String
  learner           User                @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  certificateType   CertificateType     @default(CAREER_PATH)
  title             String
  careerPathId      String?
  careerPath        CareerPath?         @relation(fields: [careerPathId], references: [id])
  shortCourseId     String?
  shortCourse       ShortCourse?        @relation(fields: [shortCourseId], references: [id])
  skillsValidated   String[]            @default([])
  projectsValidated String[]            @default([])
  finalScore        Int?
  mention           CertificateMention?
  certificateNumber String              @unique
  qrCode            String?
  verificationUrl   String?
  issuedAt          DateTime            @default(now())
  status            CredentialStatus    @default(ACTIVE)

  @@unique([learnerId, careerPathId])
  @@unique([learnerId, shortCourseId])
  @@index([learnerId])
  @@index([certificateNumber])
}

model PortfolioItem {
  id            String               @id @default(cuid())
  learnerId     String
  learner       User                 @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  projectId     String?
  project       ProfessionalProject? @relation(fields: [projectId], references: [id])
  title         String
  description   String?
  problemSolved String?
  toolsUsed     String[]             @default([])
  skillsUsed    String[]             @default([])
  images        String[]             @default([])
  demoUrl       String?
  sourceUrl     String?
  documentUrl   String?
  visibility    PortfolioVisibility  @default(PRIVATE)
  mentorComment String?
  order         Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([learnerId])
}

model Enrollment {
  id            String           @id @default(cuid())
  learnerId     String
  learner       User             @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  careerPathId  String?
  careerPath    CareerPath?      @relation(fields: [careerPathId], references: [id])
  shortCourseId String?
  shortCourse   ShortCourse?     @relation(fields: [shortCourseId], references: [id])
  status        EnrollmentStatus @default(ACTIVE)
  accessType    AccessType       @default(PAID)
  progress      Int              @default(0)
  enrolledAt    DateTime         @default(now())
  completedAt   DateTime?

  payment           Payment?
  lessonCompletions LessonProgress[]

  @@unique([learnerId, careerPathId])
  @@unique([learnerId, shortCourseId])
  @@index([learnerId])
  @@index([careerPathId])
  @@index([shortCourseId])
}

/// Complétion d'une leçon par un apprenant (permet reprise, coche par leçon,
/// et calcul fiable du pourcentage d'avancement d'une inscription).
model LessonProgress {
  id           String      @id @default(cuid())
  learnerId    String
  learner      User        @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  enrollmentId String?
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  completedAt  DateTime    @default(now())

  @@unique([learnerId, lessonId])
  @@index([learnerId])
  @@index([enrollmentId])
}

model Company {
  id           String              @id @default(cuid())
  userId       String?             @unique
  owner        User?               @relation("CompanyOwner", fields: [userId], references: [id])
  name         String
  slug         String              @unique
  logo         String?
  description  String?
  sector       String?
  website      String?
  email        String?
  phone        String?
  location     String?
  verification CompanyVerification @default(UNVERIFIED)
  status       CompanyStatus       @default(ACTIVE)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  opportunities Opportunity[]

  @@index([slug])
}

model Opportunity {
  id             String            @id @default(cuid())
  companyId      String
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title          String
  type           OpportunityType   @default(JOB)
  description    String
  requiredSkills String[]          @default([])
  location       String?
  remote         Boolean           @default(false)
  deadline       DateTime?
  compensation   String?
  status         OpportunityStatus @default(DRAFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  applications Application[]

  @@index([companyId])
  @@index([status])
}

model Application {
  id            String            @id @default(cuid())
  opportunityId String
  opportunity   Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  learnerId     String
  learner       User              @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  cvUrl         String?
  portfolioUrl  String?
  message       String?
  status        ApplicationStatus @default(RECEIVED)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([opportunityId, learnerId])
  @@index([learnerId])
}

// ═══════════════════════════════ TRANSVERSAL ════════════════════════════════

model Payment {
  id                  String          @id @default(cuid())
  learnerId           String
  learner             User            @relation(fields: [learnerId], references: [id])
  amount              Int // FCFA
  currency            String          @default("XOF")
  provider            PaymentProvider
  status              PaymentStatus   @default(PENDING)
  purpose             PaymentPurpose  @default(CAREER_PATH)
  reference           String?         @unique
  relatedEnrollmentId String?         @unique
  enrollment          Enrollment?     @relation(fields: [relatedEnrollmentId], references: [id])
  couponId            String?
  coupon              Coupon?         @relation(fields: [couponId], references: [id])
  proofUrl            String?
  metadata            Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([learnerId])
  @@index([status])
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Int
  maxUses       Int?
  currentUses   Int          @default(0)
  active        Boolean      @default(true)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())

  payments Payment[]
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json?
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String
  content     String // rich text / MDX
  coverImage  String?
  category    String?
  tags        String[]   @default([])
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  status      BlogStatus @default(DRAFT)
  readMinutes Int        @default(3)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([slug])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  company   String?
  content   String
  avatar    String?
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PortfolioProject {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  client       String
  type         String
  category     String   @default("Autre")
  year         Int      @default(2025)
  url          String?
  coverImage   String?
  images       String[] @default([])
  technologies String[] @default([])
  featured     Boolean  @default(false)
  testimonial  String?
  createdAt    DateTime @default(now())

  @@index([slug])
}

// ═══════════════════════════ PÔLE SOLUTIONS — CRM COMMERCIAL ═════════════════
// Prospection sortante + leads entrants → pipeline commun (qualification →
// opportunité → devis → négociation → conversion en projet). Organisation =
// entité centrale (peut être successivement prospect, lead, opportunité, client).
// « Deal » = opportunité commerciale (distinct du modèle Opportunity académique).

enum LifecycleStage {
  PROSPECT
  LEAD
  OPPORTUNITY
  CLIENT
  PARTNER
  FORMER_CLIENT
  ARCHIVED
}

enum OrganizationType {
  COMPANY
  SCHOOL
  UNIVERSITY
  FIRM
  CLINIC
  NGO
  ASSOCIATION
  PUBLIC_INSTITUTION
  PROFESSIONAL // particulier professionnel
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProspectStatus {
  TO_ANALYZE
  AUDIT_IN_PROGRESS
  AUDIT_COMPLETED
  READY_TO_CONTACT
  CONTACTED
  FOLLOW_UP_REQUIRED
  ENGAGED
  QUALIFIED
  CONVERTED_TO_OPPORTUNITY
  NOT_INTERESTED
  UNREACHABLE
  POSTPONED
  ARCHIVED
}

enum AuditStatus {
  DRAFT
  IN_PROGRESS
  INTERNAL_REVIEW
  TO_VALIDATE
  VALIDATED
  READY_TO_SEND
  SENT
  OUTDATED
  ARCHIVED
}

enum AuditSeverity {
  LOW
  MODERATE
  MAJOR
  CRITICAL
}

enum AuditCategory {
  SECURITY
  PERFORMANCE
  UX
  MOBILE
  SEO
  CONTENT
  INSTITUTIONAL_IMAGE
  CONVERSION
  ACCESSIBILITY
  COMPLIANCE
  MAINTENANCE
  DIGITAL_STRATEGY
  ECOMMERCE
  ENROLLMENT
  SUPPORT
  INFRASTRUCTURE
}

enum AuditDocType {
  INTERNAL_REPORT
  CLIENT_REPORT
  PDF
  DOCX
  SCREENSHOT
  EVIDENCE
  PRESENTATION
  OTHER
}

enum DocVisibility {
  INTERNAL_ONLY
  COMMERCIAL_TEAM
  CLIENT_SHAREABLE
  SHARED_WITH_CLIENT
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  WHATSAPP
  MEETING
  DOCUMENT_SENT
  AUDIT_SENT
  RESPONSE_RECEIVED
  FOLLOW_UP
  STATUS_CHANGE
  QUOTE_SENT
  PAYMENT_RECEIVED
  OTHER
}

enum ActivityVisibility {
  INTERNAL
  TEAM
  CLIENT_VISIBLE
}

enum TaskType {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  FOLLOW_UP
  AUDIT
  QUOTE
  ADMIN
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

enum DealStage {
  TO_QUALIFY
  NEED_CONFIRMED
  MEETING_SCHEDULED
  SOLUTION_PREPARATION
  PROPOSAL_SENT
  QUOTE_SENT
  NEGOTIATION
  VERBAL_AGREEMENT
  DEPOSIT_PENDING
  WON
  LOST
  POSTPONED
  ON_HOLD
}

enum DealConversionStatus {
  NOT_REQUESTED
  PENDING
  VALIDATED
  REJECTED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Organization {
  id                String           @id @default(cuid())
  name              String
  legalName         String?
  slug              String           @unique
  organizationType  OrganizationType @default(COMPANY)
  sector            String?
  subSector         String?
  description       String?
  website           String?
  email             String?
  phone             String?
  whatsapp          String?
  address           String?
  city              String?
  country           String?          @default("Côte d'Ivoire")
  googleBusinessUrl String?
  linkedinUrl       String?
  facebookUrl       String?
  instagramUrl      String?
  lifecycleStage    LifecycleStage   @default(PROSPECT)
  ownerId           String?
  owner             User?            @relation("OrgOwner", fields: [ownerId], references: [id])
  priority          Priority?
  source            String?
  notes             String?
  createdById       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  archivedAt        DateTime?

  contacts   Contact[]
  prospects  Prospect[]
  audits     Audit[]
  activities Activity[]
  tasks      Task[]
  deals      Deal[]
  quotes     Quote[]
  documents  CrmDocument[]
  leads      Lead[]
  projects   Project[]
  tags       Tag[]

  @@index([slug])
  @@index([lifecycleStage])
  @@index([ownerId])
}

model Contact {
  id               String    @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String?
  fullName         String
  jobTitle         String?
  department       String?
  email            String?
  phone            String?
  whatsapp         String?
  linkedinUrl      String?
  isPrimary        Boolean   @default(false)
  isDecisionMaker  Boolean   @default(false)
  influenceLevel   String?
  preferredChannel String?
  notes            String?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  activities        Activity[]
  receivedAudits    Audit[]   @relation("AuditRecipient")
  dealsAsPrimary    Deal[]    @relation("DealPrimaryContact")
  quotes            Quote[]
  projectsAsPrimary Project[] @relation("ProjectPrimaryContact")

  @@index([organizationId])
}

model Prospect {
  id                 String         @id @default(cuid())
  organizationId     String
  organization       Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source             String?
  status             ProspectStatus @default(TO_ANALYZE)
  priority           Priority?
  assignedToId       String?
  assignedTo         User?          @relation("ProspectAssignee", fields: [assignedToId], references: [id])
  digitalMaturity    String? // faible, moyenne, bonne, avancée
  estimatedPotential Int? // FCFA
  recommendedOffer   String?
  mainObservedNeed   String?
  lastActivityAt     DateTime?
  nextAction         String?
  nextActionDate     DateTime?
  contactStatus      String?
  createdById        String?
  createdBy          User?          @relation("ProspectCreator", fields: [createdById], references: [id])
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  archivedAt         DateTime?

  audits     Audit[]
  activities Activity[]
  tasks      Task[]
  deals      Deal[]

  @@index([organizationId])
  @@index([status])
  @@index([assignedToId])
}

model Audit {
  id                         String         @id @default(cuid())
  organizationId             String
  organization               Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  prospectId                 String?
  prospect                   Prospect?      @relation(fields: [prospectId], references: [id])
  reference                  String         @unique
  title                      String
  auditType                  String?
  version                    Int            @default(1)
  status                     AuditStatus    @default(DRAFT)
  overallSeverity            AuditSeverity?
  summary                    String?
  methodology                String?
  digitalImportanceStatement String?
  auditDate                  DateTime?
  lastVerifiedAt             DateTime?
  authorId                   String?
  author                     User?          @relation("AuditAuthor", fields: [authorId], references: [id])
  validatedById              String?
  validatedBy                User?          @relation("AuditValidator", fields: [validatedById], references: [id])
  validatedAt                DateTime?
  sentAt                     DateTime?
  sentById                   String?
  sentBy                     User?          @relation("AuditSender", fields: [sentById], references: [id])
  recipientContactId         String?
  recipientContact           Contact?       @relation("AuditRecipient", fields: [recipientContactId], references: [id])
  reviewNote                 String? // motif de refus de validation
  internalNotes              String?
  createdAt                  DateTime       @default(now())
  updatedAt                  DateTime       @updatedAt
  archivedAt                 DateTime?

  findings  AuditFinding[]
  documents AuditDocument[]
  projects  Project[]      @relation("ProjectAudit")

  @@index([organizationId])
  @@index([prospectId])
  @@index([status])
  @@index([reference])
}

model AuditFinding {
  id                   String        @id @default(cuid())
  auditId              String
  audit                Audit         @relation(fields: [auditId], references: [id], onDelete: Cascade)
  title                String
  category             AuditCategory @default(UX)
  description          String?
  severity             AuditSeverity @default(MODERATE)
  businessImpact       String?
  userImpact           String?
  securityImpact       String?
  evidenceText         String?
  evidenceUrl          String?
  affectedPageUrl      String?
  screenshotDocumentId String?
  recommendation       String?
  priorityOrder        Int           @default(0)
  isPublic             Boolean       @default(true)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([auditId])
}

model AuditDocument {
  id           String        @id @default(cuid())
  auditId      String
  audit        Audit         @relation(fields: [auditId], references: [id], onDelete: Cascade)
  documentType AuditDocType  @default(PDF)
  fileName     String
  fileUrl      String
  mimeType     String?
  size         Int?
  version      Int           @default(1)
  visibility   DocVisibility @default(INTERNAL_ONLY)
  uploadedById String?
  uploadedBy   User?         @relation("AuditDocUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime      @default(now())

  @@index([auditId])
}

model Activity {
  id             String             @id @default(cuid())
  organizationId String?
  organization   Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  prospectId     String?
  prospect       Prospect?          @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  leadId         String?
  lead           Lead?              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId         String?
  deal           Deal?              @relation(fields: [dealId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contactId      String?
  contact        Contact?           @relation(fields: [contactId], references: [id])
  type           ActivityType       @default(NOTE)
  subject        String?
  notes          String?
  activityDate   DateTime           @default(now())
  createdById    String?
  createdBy      User?              @relation("ActivityCreator", fields: [createdById], references: [id])
  visibility     ActivityVisibility @default(INTERNAL)
  createdAt      DateTime           @default(now())

  @@index([organizationId])
  @@index([prospectId])
  @@index([dealId])
  @@index([leadId])
  @@index([projectId])
}

model Task {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  prospectId     String?
  prospect       Prospect?     @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  leadId         String?
  lead           Lead?         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId         String?
  deal           Deal?         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  type           TaskType      @default(FOLLOW_UP)
  priority       Priority      @default(MEDIUM)
  status         TaskStatus    @default(TODO)
  assignedToId   String?
  assignedTo     User?         @relation("TaskAssignee", fields: [assignedToId], references: [id])
  createdById    String?
  createdBy      User?         @relation("TaskCreator", fields: [createdById], references: [id])
  dueDate        DateTime?
  completedAt    DateTime?
  reminderAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([assignedToId])
  @@index([status])
  @@index([dueDate])
}

model Deal {
  id                      String               @id @default(cuid())
  organizationId          String
  organization            Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  prospectId              String?
  prospect                Prospect?            @relation(fields: [prospectId], references: [id])
  inboundLeadId           String?              @unique
  inboundLead             Lead?                @relation("DealInboundLead", fields: [inboundLeadId], references: [id])
  primaryContactId        String?
  primaryContact          Contact?             @relation("DealPrimaryContact", fields: [primaryContactId], references: [id])
  title                   String
  description             String?
  stage                   DealStage            @default(TO_QUALIFY)
  estimatedAmount         Int? // FCFA
  currency                String               @default("XOF")
  probability             Int? // 0-100
  expectedCloseDate       DateTime?
  assignedToId            String?
  assignedTo              User?                @relation("DealAssignee", fields: [assignedToId], references: [id])
  recommendedOffer        String?
  identifiedNeed          String?
  competitors             String[]             @default([])
  lossReason              String?
  wonAt                   DateTime?
  lostAt                  DateTime?
  conversionStatus        DealConversionStatus @default(NOT_REQUESTED)
  conversionRequestedAt   DateTime?
  conversionRequestedById String?
  conversionValidatedAt   DateTime?
  conversionValidatedById String?
  conversionNote          String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  archivedAt              DateTime?

  quotes     Quote[]
  activities Activity[]
  tasks      Task[]
  project    Project?   @relation("DealProject")

  @@index([organizationId])
  @@index([stage])
  @@index([assignedToId])
}

model Quote {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  dealId         String?
  deal           Deal?         @relation(fields: [dealId], references: [id])
  contactId      String?
  contact        Contact?      @relation(fields: [contactId], references: [id])
  number         String        @unique
  title          String
  items          Json // [{ label, quantity, unitPrice }]
  amount         Int           @default(0)
  tax            Int           @default(0)
  total          Int           @default(0)
  currency       String        @default("XOF")
  status         QuoteStatus   @default(DRAFT)
  notes          String?
  createdById    String?
  createdBy      User?         @relation("QuoteCreator", fields: [createdById], references: [id])
  validatedById  String?
  sentAt         DateTime?
  acceptedAt     DateTime?
  rejectedAt     DateTime?
  expiresAt      DateTime?
  documentUrl    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project Project? @relation("QuoteProject")

  @@index([organizationId])
  @@index([dealId])
  @@index([status])
}

model CrmDocument {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  documentType   AuditDocType  @default(OTHER)
  fileName       String
  fileUrl        String
  mimeType       String?
  size           Int?
  visibility     DocVisibility @default(INTERNAL_ONLY)
  uploadedById   String?
  uploadedBy     User?         @relation("DocUploader", fields: [uploadedById], references: [id])
  createdAt      DateTime      @default(now())

  @@index([organizationId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  color     String?
  createdAt DateTime @default(now())

  organizations Organization[]

  @@index([slug])
}

/// Journal des opérations sensibles du CRM (création/attribution/validation/
/// envoi/conversion/suppression…). userId/userName conservés en clair pour
/// survivre à la suppression d'un compte (pas de FK).
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userName  String?
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ip        String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}
