// ─────────────────────────────────────────────────────────────────────────────
// Digital Access — Schéma Prisma unifié
// Couvre les deux applications : apps/web (Solutions) et apps/academy (Academy).
// Un compte unique, plusieurs rôles cumulables. Montants en FCFA (Int, sans décimale).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  // `rhel-openssl-3.0.x` = runtime serverless Vercel (en plus de la machine locale).
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ═══════════════════════════════ ENUMS ══════════════════════════════════════

enum UserRole {
  LEARNER
  CLIENT
  INSTRUCTOR
  MENTOR
  REVIEWER
  COMPANY
  ACADEMIC_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ── Pôle Solutions ──
enum LeadStatus {
  NEW
  CONTACTED
  QUOTE_SENT
  NEGOTIATION
  WON
  LOST
}

enum ProjectType {
  SITE_VITRINE
  SITE_INSTITUTIONNEL
  ELEARNING
  REFONTE
  MAINTENANCE
  OTHER
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  DELIVERED
  MAINTENANCE
  ARCHIVED
}

enum StageStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum MaintenancePlan {
  BASIC
  STANDARD
  PREMIUM
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ── Pôle Academy ──
enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum ContentStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  TEXT
  EXERCISE
  QUIZ
  RESOURCE
  LIVE
}

enum SkillCategory {
  TECHNICAL
  PROFESSIONAL
  METHODOLOGICAL
  ENTREPRENEURIAL
  TRANSVERSAL
}

enum MasteryLevel {
  UNDERSTOOD
  APPLIED
  MASTERED
  PROFESSIONAL
}

enum QuizQuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  TRUE_FALSE
  MATCHING
  FILL_BLANK
  ORDERING
  SHORT_ANSWER
  SCENARIO
}

enum ProfessionalProjectType {
  EXERCISE
  MINI_PROJECT
  PROFESSIONAL_MISSION
  FINAL_PROJECT
  CLIENT_PROJECT
  COLLABORATIVE_PROJECT
}

enum SubmissionStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  VALIDATED
  REJECTED
  PORTFOLIO_READY
}

enum BadgeCategory {
  TECHNICAL_SKILL
  PROFESSIONAL_SKILL
  PROJECT
  EXCELLENCE
  ENGAGEMENT
  TALENT
}

enum CredentialStatus {
  ACTIVE
  SUSPENDED
  REVOKED
  EXPIRED
}

enum CertificateType {
  SHORT_COURSE
  MICRO_CERTIFICATION
  CAREER_PATH
  ADVANCED_CERTIFICATE
}

enum CertificateMention {
  VALIDATED
  GOOD
  VERY_GOOD
  EXCELLENCE
}

enum PortfolioVisibility {
  PRIVATE
  PUBLIC
  LINK_ONLY
  COMPANIES_ONLY
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  EXPIRED
}

enum AccessType {
  PAID
  FREE
  COUPON
  GRANT
  COMPANY
  MANUAL
}

enum CompanyVerification {
  UNVERIFIED
  VERIFIED
  PARTNER
  PREMIUM
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
}

enum OpportunityType {
  INTERNSHIP
  JOB
  FREELANCE
  CLIENT_PROJECT
  APPRENTICESHIP
}

enum OpportunityStatus {
  DRAFT
  PUBLISHED
  CLOSED
  EXPIRED
}

enum ApplicationStatus {
  RECEIVED
  REVIEWED
  SHORTLISTED
  INTERVIEW
  ACCEPTED
  REJECTED
}

// ── Transversal ──
enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  MANUAL_REVIEW
  REFUNDED
}

enum PaymentProvider {
  MOBILE_MONEY
  PAYDUNYA
  CINETPAY
  MANUAL
  FREE
}

enum PaymentPurpose {
  SHORT_COURSE
  CAREER_PATH
  B2B
  OTHER
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NotificationType {
  LEAD_NEW
  TICKET_NEW
  DELIVERABLE_ADDED
  INVOICE_SENT
  PROJECT_STATUS
  COURSE_ENROLLED
  PROGRESS_MILESTONE
  CERTIFICATE_ISSUED
  PAYMENT_CONFIRMED
  FORUM_REPLY
  CHAT_MENTION
  STREAK_REMINDER
  // Academy (refonte)
  ENROLLMENT_CONFIRMED
  ACCESS_ACTIVATED
  MODULE_AVAILABLE
  PROJECT_SUBMITTED
  PROJECT_FEEDBACK
  BADGE_EARNED
  OPPORTUNITY_NEW
  APPLICATION_UPDATE
  SYSTEM
}

// ═══════════════════════════════ USER & AUTH ════════════════════════════════

model User {
  id                String     @id @default(cuid())
  name              String
  email             String     @unique
  password          String? // null pour comptes OAuth uniquement
  avatar            String?
  bio               String?
  location          String?
  phone             String?
  website           String?
  roles             UserRole[] @default([LEARNER])
  emailVerified     DateTime?
  isActive          Boolean    @default(false)
  streak            Int        @default(0)
  xp                Int        @default(0)
  lastActiveAt      DateTime?
  deletedAt         DateTime? // soft delete (rétention 30j)
  notificationPrefs Json? // { email: {COURSE_ENROLLED: bool, ...}, inApp: {...} } — null = tout activé
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  // Auth.js
  accounts           Account[]
  sessions           Session[]
  verificationTokens VerificationToken[]

  // Pôle Solutions
  assignedLeads       Lead[]                @relation("LeadAssignee")
  projects            Project[]             @relation("ClientProjects")
  invoices            Invoice[]
  maintenanceContract MaintenanceContract[]
  tickets             Ticket[]
  ticketMessages      TicketMessage[]
  projectMessages     ProjectMessage[]

  // Pôle Academy (refonte)
  learnerProfile      LearnerProfile?
  enrollments         Enrollment[]
  lessonProgress      LessonProgress[]
  learnerBadges       LearnerBadge[]
  certificates        Certificate[]
  portfolioItems      PortfolioItem[]
  submissions         ProjectSubmission[] @relation("LearnerSubmissions")
  reviewedSubmissions ProjectSubmission[] @relation("ReviewerSubmissions")
  quizAttempts        QuizAttempt[]
  applications        Application[]
  companyProfile      Company?            @relation("CompanyOwner")

  // Transversal
  payments      Payment[]
  notifications Notification[]
  blogPosts     BlogPost[]

  @@index([email])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  type      TokenType
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

// ═══════════════════════════════ PÔLE SOLUTIONS ═════════════════════════════

model Lead {
  id          String      @id @default(cuid())
  name        String
  email       String
  phone       String?
  company     String?
  projectType ProjectType
  budget      String?
  timeline    String?
  message     String
  documents   String[]    @default([])
  status      LeadStatus  @default(NEW)
  source      String? // devis, contact, référence...
  notes       String?
  assigneeId  String?
  assignee    User?       @relation("LeadAssignee", fields: [assigneeId], references: [id])
  project     Project?
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Project {
  id          String        @id @default(cuid())
  clientId    String
  client      User          @relation("ClientProjects", fields: [clientId], references: [id])
  leadId      String?       @unique
  lead        Lead?         @relation(fields: [leadId], references: [id])
  title       String
  slug        String        @unique
  type        ProjectType
  description String
  budget      Int? // FCFA
  status      ProjectStatus @default(PENDING)
  startDate   DateTime?
  endDate     DateTime?
  liveUrl     String?
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  stages   ProjectStage[]
  invoices Invoice[]
  tickets  Ticket[]
  messages ProjectMessage[]
  contract MaintenanceContract?

  @@index([clientId])
  @@index([status])
}

model ProjectStage {
  id           String      @id @default(cuid())
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  status       StageStatus @default(PENDING)
  position     Int
  deliverables String[]    @default([]) // URLs Vercel Blob
  completedAt  DateTime?
  createdAt    DateTime    @default(now())

  @@index([projectId])
}

model Invoice {
  id        String        @id @default(cuid())
  projectId String?
  project   Project?      @relation(fields: [projectId], references: [id])
  clientId  String
  client    User          @relation(fields: [clientId], references: [id])
  number    String        @unique
  items     Json // [{ label, quantity, unitPrice }]
  amount    Int // sous-total FCFA
  tax       Int           @default(0)
  total     Int // FCFA
  status    InvoiceStatus @default(DRAFT)
  dueDate   DateTime?
  paidAt    DateTime?
  pdfUrl    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
}

model MaintenanceContract {
  id            String          @id @default(cuid())
  projectId     String          @unique
  project       Project         @relation(fields: [projectId], references: [id])
  clientId      String
  client        User            @relation(fields: [clientId], references: [id])
  plan          MaintenancePlan
  services      String[]        @default([])
  startDate     DateTime
  endDate       DateTime
  autoRenew     Boolean         @default(true)
  monthlyAmount Int // FCFA
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([clientId])
}

model Ticket {
  id          String          @id @default(cuid())
  projectId   String?
  project     Project?        @relation(fields: [projectId], references: [id])
  clientId    String
  client      User            @relation(fields: [clientId], references: [id])
  title       String
  description String
  priority    TicketPriority  @default(MEDIUM)
  status      TicketStatus    @default(OPEN)
  attachments String[]        @default([])
  messages    TicketMessage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([clientId])
  @@index([status])
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  content     String
  attachments String[] @default([])
  createdAt   DateTime @default(now())

  @@index([ticketId])
}

model ProjectMessage {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  content     String
  attachments String[] @default([])
  createdAt   DateTime @default(now())

  @@index([projectId])
}

// ═══════════════════════════════ PÔLE ACADEMY ═══════════════════════════════
// Académie orientée compétences : École → Parcours métier → Module → Leçon →
// Quiz → Projets professionnels → Dépôts → Badges → Portfolio → Certificats →
// Opportunités. Refonte complète (2026) — cf. docs/academy/.

model School {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  shortDescription String
  longDescription  String?
  icon             String?
  image            String?
  color            String?
  order            Int           @default(0)
  status           ContentStatus @default(PUBLISHED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  careerPaths  CareerPath[]
  shortCourses ShortCourse[]
  skills       Skill[]
  projects     ProfessionalProject[]

  @@index([slug])
}

model LearnerProfile {
  id           String              @id @default(cuid())
  userId       String              @unique
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline     String?
  bio          String?
  city         String?
  country      String?             @default("Côte d'Ivoire")
  linkedinUrl  String?
  githubUrl    String?
  portfolioUrl String?
  availability String?
  careerGoal   String?
  visibility   PortfolioVisibility @default(PRIVATE)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model CareerPath {
  id               String        @id @default(cuid())
  schoolId         String
  school           School        @relation(fields: [schoolId], references: [id])
  title            String
  slug             String        @unique
  shortDescription String
  longDescription  String?
  targetJob        String
  level            Level         @default(BEGINNER)
  duration         String? // libellé, ex. « 3 mois »
  estimatedHours   Int?
  price            Int           @default(0) // FCFA
  prerequisites    String[]      @default([])
  objectives       String[]      @default([])
  outcomes         String[]      @default([])
  tools            String[]      @default([])
  certificateTitle String?
  coverImage       String?
  featured         Boolean       @default(false)
  status           ContentStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  modules      Module[]
  skills       CareerPathSkill[]
  projects     ProfessionalProject[]
  enrollments  Enrollment[]
  certificates Certificate[]

  @@index([schoolId])
  @@index([slug])
  @@index([status])
}

model ShortCourse {
  id               String        @id @default(cuid())
  schoolId         String
  school           School        @relation(fields: [schoolId], references: [id])
  title            String
  slug             String        @unique
  shortDescription String
  longDescription  String?
  level            Level         @default(BEGINNER)
  duration         String?
  price            Int           @default(0) // FCFA
  courseType       String? // initiation, atelier, outil, module bonus…
  objectives       String[]      @default([])
  prerequisites    String[]      @default([])
  coverImage       String?
  featured         Boolean       @default(false)
  status           ContentStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  modules      Module[]
  enrollments  Enrollment[]
  certificates Certificate[]

  @@index([schoolId])
  @@index([slug])
  @@index([status])
}

model Module {
  id                String        @id @default(cuid())
  careerPathId      String?
  careerPath        CareerPath?   @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  shortCourseId     String?
  shortCourse       ShortCourse?  @relation(fields: [shortCourseId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  order             Int           @default(0)
  objectives        String[]      @default([])
  estimatedDuration Int? // minutes
  status            ContentStatus @default(PUBLISHED)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  lessons  Lesson[]
  quizzes  Quiz[]
  projects ProfessionalProject[]

  @@index([careerPathId])
  @@index([shortCourseId])
}

model Lesson {
  id                String        @id @default(cuid())
  moduleId          String
  module            Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title             String
  slug              String
  content           String? // markdown / MDX
  videoUrl          String?
  lessonType        LessonType    @default(VIDEO)
  resources         Json?
  order             Int           @default(0)
  estimatedDuration Int? // minutes
  isPreview         Boolean       @default(false)
  status            ContentStatus @default(PUBLISHED)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  quizzes     Quiz[]
  completions LessonProgress[]

  @@index([moduleId])
}

model Skill {
  id          String        @id @default(cuid())
  schoolId    String?
  school      School?       @relation(fields: [schoolId], references: [id])
  name        String
  slug        String        @unique
  description String?
  category    SkillCategory @default(TECHNICAL)
  level       Level         @default(BEGINNER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  careerPaths CareerPathSkill[]
  badges      Badge[]

  @@index([schoolId])
  @@index([category])
}

model CareerPathSkill {
  careerPathId String
  careerPath   CareerPath @relation(fields: [careerPathId], references: [id], onDelete: Cascade)
  skillId      String
  skill        Skill      @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([careerPathId, skillId])
  @@index([skillId])
}

model Quiz {
  id              String        @id @default(cuid())
  lessonId        String?
  lesson          Lesson?       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  moduleId        String?
  module          Module?       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  passingScore    Int           @default(70)
  attemptsAllowed Int           @default(0) // 0 = illimité
  status          ContentStatus @default(PUBLISHED)
  createdAt       DateTime      @default(now())

  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([lessonId])
  @@index([moduleId])
}

model QuizQuestion {
  id            String           @id @default(cuid())
  quizId        String
  quiz          Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question      String
  type          QuizQuestionType @default(SINGLE_CHOICE)
  options       Json?
  correctAnswer Json
  explanation   String?
  points        Int              @default(1)
  order         Int              @default(0)

  @@index([quizId])
}

model QuizAttempt {
  id          String    @id @default(cuid())
  quizId      String
  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  learnerId   String
  learner     User      @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  score       Int       @default(0)
  passed      Boolean   @default(false)
  answers     Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([quizId])
  @@index([learnerId])
}

model ProfessionalProject {
  id                  String                  @id @default(cuid())
  schoolId            String?
  school              School?                 @relation(fields: [schoolId], references: [id])
  careerPathId        String?
  careerPath          CareerPath?             @relation(fields: [careerPathId], references: [id])
  moduleId            String?
  module              Module?                 @relation(fields: [moduleId], references: [id])
  title               String
  slug                String                  @unique
  projectType         ProfessionalProjectType @default(MINI_PROJECT)
  level               Level                   @default(BEGINNER)
  context             String?
  problem             String?
  mission             String?
  objectives          String[]                @default([])
  deliverables        String[]                @default([])
  resources           Json?
  constraints         String[]                @default([])
  estimatedDuration   Int? // heures
  requiresSubmission  Boolean                 @default(true)
  requiresDefense     Boolean                 @default(false)
  isPortfolioEligible Boolean                 @default(true)
  rubricId            String?
  rubric              Rubric?                 @relation(fields: [rubricId], references: [id])
  status              ContentStatus           @default(DRAFT)
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  submissions    ProjectSubmission[]
  badges         Badge[]
  portfolioItems PortfolioItem[]

  @@index([schoolId])
  @@index([careerPathId])
  @@index([slug])
}

model Rubric {
  id           String   @id @default(cuid())
  title        String
  description  String?
  totalPoints  Int      @default(100)
  passingScore Int      @default(70)
  criteria     Json // [{ label, points, description }]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects ProfessionalProject[]
}

model ProjectSubmission {
  id            String              @id @default(cuid())
  projectId     String
  project       ProfessionalProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  learnerId     String
  learner       User                @relation("LearnerSubmissions", fields: [learnerId], references: [id], onDelete: Cascade)
  files         Json?
  links         Json?
  comment       String?
  aiDeclaration String?
  status        SubmissionStatus    @default(IN_PROGRESS)
  score         Int?
  feedback      String?
  reviewerId    String?
  reviewer      User?               @relation("ReviewerSubmissions", fields: [reviewerId], references: [id])
  version       Int                 @default(1)
  submittedAt   DateTime?
  reviewedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([projectId])
  @@index([learnerId])
  @@index([status])
}

model Badge {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique
  description String
  category    BadgeCategory        @default(TECHNICAL_SKILL)
  level       Level?
  icon        String?
  criteria    String?
  skillId     String?
  skill       Skill?               @relation(fields: [skillId], references: [id])
  projectId   String?
  project     ProfessionalProject? @relation(fields: [projectId], references: [id])
  status      ContentStatus        @default(PUBLISHED)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  learnerBadges LearnerBadge[]

  @@index([slug])
  @@index([category])
}

model LearnerBadge {
  id           String           @id @default(cuid())
  learnerId    String
  learner      User             @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  badgeId      String
  badge        Badge            @relation(fields: [badgeId], references: [id])
  evidenceType String?
  evidenceId   String?
  issuedAt     DateTime         @default(now())
  status       CredentialStatus @default(ACTIVE)

  @@unique([learnerId, badgeId])
  @@index([learnerId])
}

model Certificate {
  id                String              @id @default(cuid())
  learnerId         String
  learner           User                @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  certificateType   CertificateType     @default(CAREER_PATH)
  title             String
  careerPathId      String?
  careerPath        CareerPath?         @relation(fields: [careerPathId], references: [id])
  shortCourseId     String?
  shortCourse       ShortCourse?        @relation(fields: [shortCourseId], references: [id])
  skillsValidated   String[]            @default([])
  projectsValidated String[]            @default([])
  finalScore        Int?
  mention           CertificateMention?
  certificateNumber String              @unique
  qrCode            String?
  verificationUrl   String?
  issuedAt          DateTime            @default(now())
  status            CredentialStatus    @default(ACTIVE)

  @@unique([learnerId, careerPathId])
  @@unique([learnerId, shortCourseId])
  @@index([learnerId])
  @@index([certificateNumber])
}

model PortfolioItem {
  id            String               @id @default(cuid())
  learnerId     String
  learner       User                 @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  projectId     String?
  project       ProfessionalProject? @relation(fields: [projectId], references: [id])
  title         String
  description   String?
  problemSolved String?
  toolsUsed     String[]             @default([])
  skillsUsed    String[]             @default([])
  images        String[]             @default([])
  demoUrl       String?
  sourceUrl     String?
  documentUrl   String?
  visibility    PortfolioVisibility  @default(PRIVATE)
  mentorComment String?
  order         Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([learnerId])
}

model Enrollment {
  id            String           @id @default(cuid())
  learnerId     String
  learner       User             @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  careerPathId  String?
  careerPath    CareerPath?      @relation(fields: [careerPathId], references: [id])
  shortCourseId String?
  shortCourse   ShortCourse?     @relation(fields: [shortCourseId], references: [id])
  status        EnrollmentStatus @default(ACTIVE)
  accessType    AccessType       @default(PAID)
  progress      Int              @default(0)
  enrolledAt    DateTime         @default(now())
  completedAt   DateTime?

  payment           Payment?
  lessonCompletions LessonProgress[]

  @@unique([learnerId, careerPathId])
  @@unique([learnerId, shortCourseId])
  @@index([learnerId])
  @@index([careerPathId])
  @@index([shortCourseId])
}

/// Complétion d'une leçon par un apprenant (permet reprise, coche par leçon,
/// et calcul fiable du pourcentage d'avancement d'une inscription).
model LessonProgress {
  id           String      @id @default(cuid())
  learnerId    String
  learner      User        @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  enrollmentId String?
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  completedAt  DateTime    @default(now())

  @@unique([learnerId, lessonId])
  @@index([learnerId])
  @@index([enrollmentId])
}

model Company {
  id           String              @id @default(cuid())
  userId       String?             @unique
  owner        User?               @relation("CompanyOwner", fields: [userId], references: [id])
  name         String
  slug         String              @unique
  logo         String?
  description  String?
  sector       String?
  website      String?
  email        String?
  phone        String?
  location     String?
  verification CompanyVerification @default(UNVERIFIED)
  status       CompanyStatus       @default(ACTIVE)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  opportunities Opportunity[]

  @@index([slug])
}

model Opportunity {
  id             String            @id @default(cuid())
  companyId      String
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title          String
  type           OpportunityType   @default(JOB)
  description    String
  requiredSkills String[]          @default([])
  location       String?
  remote         Boolean           @default(false)
  deadline       DateTime?
  compensation   String?
  status         OpportunityStatus @default(DRAFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  applications Application[]

  @@index([companyId])
  @@index([status])
}

model Application {
  id            String            @id @default(cuid())
  opportunityId String
  opportunity   Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  learnerId     String
  learner       User              @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  cvUrl         String?
  portfolioUrl  String?
  message       String?
  status        ApplicationStatus @default(RECEIVED)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([opportunityId, learnerId])
  @@index([learnerId])
}

// ═══════════════════════════════ TRANSVERSAL ════════════════════════════════

model Payment {
  id                  String          @id @default(cuid())
  learnerId           String
  learner             User            @relation(fields: [learnerId], references: [id])
  amount              Int // FCFA
  currency            String          @default("XOF")
  provider            PaymentProvider
  status              PaymentStatus   @default(PENDING)
  purpose             PaymentPurpose  @default(CAREER_PATH)
  reference           String?         @unique
  relatedEnrollmentId String?         @unique
  enrollment          Enrollment?     @relation(fields: [relatedEnrollmentId], references: [id])
  couponId            String?
  coupon              Coupon?         @relation(fields: [couponId], references: [id])
  proofUrl            String?
  metadata            Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([learnerId])
  @@index([status])
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Int
  maxUses       Int?
  currentUses   Int          @default(0)
  active        Boolean      @default(true)
  expiresAt     DateTime?
  createdAt     DateTime     @default(now())

  payments Payment[]
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json?
  link      String?
  createdAt DateTime         @default(now())

  @@index([userId, read])
}

model BlogPost {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String
  content     String // rich text / MDX
  coverImage  String?
  category    String?
  tags        String[]   @default([])
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  status      BlogStatus @default(DRAFT)
  readMinutes Int        @default(3)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
  @@index([slug])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  company   String?
  content   String
  avatar    String?
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PortfolioProject {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  client       String
  type         String
  category     String   @default("Autre")
  year         Int      @default(2025)
  url          String?
  coverImage   String?
  images       String[] @default([])
  technologies String[] @default([])
  featured     Boolean  @default(false)
  testimonial  String?
  createdAt    DateTime @default(now())

  @@index([slug])
}
